package Excel_practise;

class Employee{
	String Empname="Rahul";
	double Empsalary=10000;
	
	public void DisplayInformation() {
		System.out.println("EMpname name is" +" "+Empname+" "+"and Salary is"+Empsalary);
	}
}
class Developer extends Employee{
	void role(){
		System.out.println("Role : Backend Developer");
	}
}
class Manager extends Employee{
	void role()
	{
		System.out.println("Role : IT Department");
	}
}

public class Day3_inheriteance {
	public static void main(String[] args) {
		
		Developer d=new Developer();
		d.role();
		d.DisplayInformation();
		
		System.out.println("====================================");
		
		Manager m=new Manager();
		m.role();
		m.DisplayInformation();
		
		
		
	}
}
