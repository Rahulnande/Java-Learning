package Collection;

import java.util.Stack;

public class prac3_stack {
	public static void main(String[] args) {
		
		Stack s=new Stack();
		
		//add element
		s.push("rahul");
		s.push(1);
		s.push(null);
		s.push(12);
		
		System.out.println(s);
		
		//get last elemnet
		System.out.println(s.peek());
		//remove last element
		System.out.println(s.pop());
		System.out.println(s);
		
	}

}
